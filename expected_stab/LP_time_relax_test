# --------------------------------------------------------------------
#  Basic container for a job’s distributions
# --------------------------------------------------------------------
struct JobDistribution
    start_dist::UnivariateDistribution
    end_dist::UnivariateDistribution
end

# --------------------------------------------------------------------
#  Bit‑set helpers
# --------------------------------------------------------------------
@inline bits_from_set(S::AbstractVector{Int}) =
    foldl((b,i)->b | (1 << (i-1)), S; init = 0)

function set_from_bits(bits::Int, n::Int)
    out = Int[]
    for i in 1:n
        ((bits >> (i-1)) & 1 == 1) && push!(out,i)
    end
    return out
end

@inline contiguous(v::Vector{Int}) =
    length(v) ≤ 1 || (maximum(v)-minimum(v)+1 == length(v))

# --------------------------------------------------------------------
#  Renormalised pmf on a restricted support L
# --------------------------------------------------------------------
function renorm(dist::UnivariateDistribution, L_bits::Int, m::Int)
    supp  = [i for i in 1:m if (L_bits >> (i-1)) & 1 == 1]
    probs = pdf.(dist, supp)
    Z = sum(probs)
    Z == 0 && return Dict{Int,Float64}()
    return Dict(supp[i] => probs[i]/Z for i in eachindex(supp))
end

# --------------------------------------------------------------------
#  Probability that job `job` occupies exactly `occ_bits` ⊆ L′
# --------------------------------------------------------------------
function p_occ_exact(job::JobDistribution, occ_bits, Lp_bits, m)
    occ_bits == 0 && return 0.0
    # (occ_bits & ~Lp_bits) == 0 || return 0.0
    iv = set_from_bits(occ_bits,m)
    contiguous(iv) || return 0.0
    s = minimum(iv); e = maximum(iv)
    p_s = renorm(job.start_dist, Lp_bits, m)
    p_e = renorm(job.end_dist,   Lp_bits, m)
    return get(p_s,s,0.0)*get(p_e,e,0.0)
end

# --------------------------------------------------------------------
#  Probability that job `job` conflicts with `occ_bits` (hence deleted)
# --------------------------------------------------------------------
function p_deleted(job::JobDistribution, occ_bits, Lp_bits, m)
    occ_bits == 0 && return 0.0
    occ   = Set(set_from_bits(occ_bits,m))
    p_s   = renorm(job.start_dist, Lp_bits, m)
    p_e   = renorm(job.end_dist,   Lp_bits, m)
    p_del = 0.0
    for (s,ps) in p_s, (e,pe) in p_e
        e < s && continue
        intersects = !isempty(intersect(occ, Set(s:e)))
        intersects || continue
        p_del += ps*pe
    end
    # if p_del > 0
    #     return 1
    # end
    return p_del
end

@inline (A::Int) ⊆ (B::Int) = (A & B) == A

# --------------------------------------------------------------------
#  Transition probability  P[(S',L') | (S,L), a]
# --------------------------------------------------------------------
function trans_prob(S_bits,L_bits,S1_bits,L1_bits,a,jobs,m)
    # has_a_in_S1      = ((S1_bits >> (a-1)) & 1) == 1
    # S1_without_a     = S1_bits & ~(1 << (a-1))
    # has_a_in_S1 && (S_bits == S1_without_a) || return 0.0
    n = length(jobs)
    # isequal(set_from_bits(S1_bits,n), setdiff(set_from_bits(S_bits,n), [a])) || return 0.0
    (S1_bits & ~S_bits) == 0 && (S_bits != S1_bits) || return 0.0
    ((S1_bits >> (a - 1)) & 1) == 1 && return 0
    # if a in set_from_bits(S1_bits,n) return 0 end
    # (L_bits & ~L1_bits) == 0 || return 0.0
    if isempty(setdiff(set_from_bits(L_bits,m),set_from_bits(L1_bits,m))) ||  !all(in(set_from_bits(L_bits,m)), set_from_bits(L1_bits,m)) return 0 end
    occ_bits = L_bits & ~L1_bits             # positions taken by a
    p_occ = p_occ_exact(jobs[a],occ_bits,L_bits,m)
    p_occ == 0.0 && return 0.0

    p_survive = 1.0
    n = length(jobs)
    for j in set_from_bits(S_bits,n)
        j==a && continue
        # in_S  = (S_bits  >> (j-1)) & 1 == 1
        in_S1 = (S1_bits >> (j-1)) & 1 == 1
        # in_S || in_S1 || continue
        p_del = p_deleted(jobs[j],occ_bits,L_bits,m)
        println("p_del for job $j: ", p_del)
        # println("\np_del for job $j: ", p_del)
        p_survive *= in_S1 ? (1-p_del) : p_del
        # p_survive *= 1-p_del
    end
    return p_occ * p_survive
end

