function build_schedule_lp(jobs::Vector{JobDistribution},
                               w::Vector{<:Real}, m::Int)
    n = length(jobs)
    n == length(w) || error("w length ≠ #jobs")

    allS = (1<<n)-1;   allL = (1<<m)-1
    job_bits = collect(0:(1<<n)-1)     # all subsets of jobs
    pos_bits = collect(0:(1<<m)-1)     # all subsets of slots

    model = Model(COPT.Optimizer)
    set_silent(model)
    # 1) aggregated variables in the *same* model
    @variable(model, y[1:m, 1:n] >= 0)



    # ---------------- variables -----------------
    x = Dict{NTuple{4,Int}, VariableRef}()     # (t,S,L,j)

    for t in 1:m
        for S in job_bits, L in pos_bits
            S == 0 && continue                 # no action if no job alive
            for j in set_from_bits(S, n)
                x[(t,S,L,j)] = @variable(model, lower_bound = 0.0,
                                          base_name = "x_t$(t)_S$(S)_L$(L)_j$(j)")
            end
        end
    end

    # helper: sum of actions taken in state (t,S,L)
    function xsum_expr(t,S,L)
        terms = [x[(t,S,L,j)] for j in set_from_bits(S,n)
                              if haskey(x,(t,S,L,j))]
        return isempty(terms) ? 0.0 : sum(terms)
    end

    # ---------------- objective -----------------
    @objective(model, Max,
        sum(w[j] * xval  for ((_,_,_,j), xval) in x))

    # ---------------- constraints ---------------
    # 1.  initial‑state reachability
    @constraint(model,  xsum_expr(1, allS, allL)  <= 1)
    for S in job_bits, L in pos_bits
        (S == allS && L == allL) && continue
        @constraint(model,  xsum_expr(1,S,L) == 0)
    end

    # 2.  flow constraints without z
    for t in 2:m
        for S1 in job_bits, L1 in pos_bits
            lhs = xsum_expr(t, S1, L1)

            # build RHS = Σ p * x_{t-1,S,L,a}
            rhs = AffExpr()
            for S in job_bits, L in pos_bits
                S == 0 && continue
                for a in set_from_bits(S,n)
                    key = (t-1,S,L,a)
                    haskey(x, key) || continue
                    p = trans_prob(S, L, S1, L1, a, jobs, m)
                    p == 0.0 && continue
                    rhs += p * x[key]
                end
            end
            @constraint(model, lhs <= rhs)
        end
    end
    # 2) equality  y[t,j] = Σ_{S,L} x[t,S,L,j]
    for t in 1:m, j in 1:n
        terms = [x[(t,S,L,j)] for ((tt,S,L,jj), xvar) in x if tt == t && jj == j]
        isempty(terms) && continue                 # no action variables for this (t,j)
        @constraint(model, y[t,j] - sum(terms) == 0)
    end

    return model, x
end


# --------------------------------------------------------------------
#  Utility: aggregate x over S,L  →  matrix (t,i)
# --------------------------------------------------------------------
function aggregate_x(xdict, m, n)
    # Return matrix with **rows = jobs (n)** and **columns = time (m)**
    mat = zeros(n, m)
    for ((t,_,_,j), var) in xdict
        mat[j, t] += value(var)
    end
    return mat
end

