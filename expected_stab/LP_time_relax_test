"Return the Polyhedra polyhedron of the LP (all constraints) via MOI + CDDLib."
# ----------------------------------------------------------------------
#  Build a Polyhedra polyhedron directly from the JuMP model
# ----------------------------------------------------------------------
function lp_polyhedron(model::JuMP.Model)
    # Polyhedra has a JuMP extension that converts a (linear) JuMP model
    # straight into an H‑representation.  We simply choose CDDLib as the
    # backend enumerator.
    # NOTE:  The call needs the *JuMP.Model* itself, **not** its MOI
    #        backend/cached optimiser.  Passing the backend causes the
    #        MethodError you hit.
    #
    #        polyhedron(model, backend) is provided by
    #        PolyhedraJuMPExt (loaded automatically when Polyhedra is
    #        imported), so no extra `using` is required.
    return Polyhedra.polyhedron(model, CDDLib.Library())
# end = JuMP.backend(model)  # MOI model behind JuMP
#     return Polyhedra.polyhedron(backend, CDDLib.Library())
end

"Map each x‑variable to its column index in the coordinate vector."
function x_index_map(xdict)
    idx_to_key = Dict{Int,Tuple{Int,Int,Int,Int}}()
    for (key, var) in xdict
        idx_to_key[JuMP.index(var).value] = key   # MOI index → variable key
    end
    return idx_to_key
end

# Convert a vertex coordinate vector → x_i^t matrix
function vertex_to_xt(coords::Vector{<:Real}, idx_to_key, m, n)
    # rows = jobs, cols = time
    mat = zeros(n, m)
    for (idx, key) in idx_to_key
        t = key[1]   # time index
        j = key[4]   # job index
        mat[j, t] += coords[idx]
    end
    return mat
end
function coords_to_xt!(mat, coords, pair)
    fill!(mat, 0.0)
    for k in eachindex(coords)
        j, t = pair[k]
        mat[j, t] += coords[k]
    end
    return mat
end

